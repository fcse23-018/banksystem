<?xml version="1.0" encoding="UTF-8"?>

<?import com.github.devjavasoft.materialfx.controls.MFXButton?>
<?import com.github.devjavasoft.materialfx.controls.MFXPasswordField?>
<?import com.github.devjavasoft.materialfx.controls.MFXTextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #f0f2f5; -fx-padding: 40;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bw.co.pulabank.controller.LoginController">
    <children>
        <Text style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-fill: #1a237e;" text="Pula Bank Login" />
        <MFXTextField fx:id="usernameField" promptText="Username" style="-fx-font-size: 16px;" />
        <MFXPasswordField fx:id="passwordField" promptText="Password" style="-fx-font-size: 16px;" />
        <MFXButton onAction="#handleLogin" style="-fx-background-color: #3f51b5; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10 20;" text="Login" />
        <Text fx:id="errorText" fill="RED" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
