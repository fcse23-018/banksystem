<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import com.jfoenix.controls.JFXPasswordField?>
<?import com.jfoenix.controls.JFXTextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.botswanabank.project.controller.LoginController">
    <children>
        <JFXTextField fx:id="emailField" layoutX="175.0" layoutY="125.0" promptText="Email" />
        <JFXPasswordField fx:id="passwordField" layoutX="175.0" layoutY="175.0" promptText="Password" />
        <JFXButton buttonType="RAISED" layoutX="250.0" layoutY="225.0" onAction="#handleLogin" style="-fx-background-color: #1877f2;" text="Log In" textFill="WHITE" />
        <Text layoutX="225.0" layoutY="75.0" text="Botswana Bank" wrappingWidth="150.0" />
        <JFXButton layoutX="240.0" layoutY="275.0" onAction="#handleRegister" text="Create New Account" />
    </children>
</AnchorPane>
