<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>

<GridPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bankingsystem.controller.TransactionDialogController" 
          hgap="10" vgap="10" style="-fx-padding: 20;">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="titleLabel" text="Transaction" style="-fx-font-size: 16px; -fx-font-weight: bold;" GridPane.columnSpan="2"/>

    <Label text="Amount:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
    <TextField fx:id="amountField" GridPane.rowIndex="1" GridPane.columnIndex="1" />

    <Label text="Description:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
    <TextField fx:id="descriptionField" GridPane.rowIndex="2" GridPane.columnIndex="1" />
    
    <Label fx:id="recipientLabel" text="Recipient Account ID:" visible="false" GridPane.rowIndex="3" GridPane.columnIndex="0" />
    <TextField fx:id="recipientField" visible="false" GridPane.rowIndex="3" GridPane.columnIndex="1" />

    <Button fx:id="confirmButton" text="Confirm" onAction="#handleConfirm" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
</GridPane>
