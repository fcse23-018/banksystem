<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bankingsystem.controller.ProfileViewController"
          hgap="10" vgap="10" style="-fx-padding: 20;">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    <columnConstraints>
        <ColumnConstraints minWidth="120" prefWidth="120"/>
        <ColumnConstraints minWidth="250" prefWidth="300" hgrow="ALWAYS"/>
    </columnConstraints>

    <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
    <TextField fx:id="firstNameField" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1" />

    <Label text="Surname:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
    <TextField fx:id="surnameField" editable="false" GridPane.rowIndex="1" GridPane.columnIndex="1" />

    <Label text="Address:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
    <TextField fx:id="addressField" editable="false" GridPane.rowIndex="2" GridPane.columnIndex="1" />

    <Label text="ID Number:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
    <TextField fx:id="idNumberField" editable="false" GridPane.rowIndex="3" GridPane.columnIndex="1" />

    <Label text="Status:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
    <TextField fx:id="statusField" editable="false" GridPane.rowIndex="4" GridPane.columnIndex="1" />

    <Button fx:id="updateButton" text="Update Profile" onAction="#handleUpdateProfile" 
            GridPane.rowIndex="5" GridPane.columnIndex="1" GridPane.halignment="RIGHT"/>

</GridPane>
