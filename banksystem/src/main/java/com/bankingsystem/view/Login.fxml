<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane fx:controller="com.bankingsystem.controller.LoginController" 
          xmlns:fx="http://javafx.com/fxml/1" 
          alignment="CENTER" hgap="10" vgap="10" style="-fx-background-color: #f0f4f8;">
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>
    <columnConstraints>
        <ColumnConstraints minWidth="100" prefWidth="100" hgrow="SOMETIMES" />
        <ColumnConstraints minWidth="200" prefWidth="200" hgrow="SOMETIMES" />
    </columnConstraints>

    <!-- Title -->
    <Label text="Banking System Login" style="-fx-font-size: 24px; -fx-font-weight: bold;" 
           GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2" GridPane.halignment="CENTER"/>

    <!-- ID Number -->
    <Label text="ID Number:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
    <TextField fx:id="idNumberField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

    <!-- Password -->
    <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
    <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="2" />

    <!-- Login Button -->
    <Button fx:id="loginButton" text="Login" onAction="#handleLogin" 
            defaultButton="true" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" 
            GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.halignment="RIGHT"/>

    <!-- Sign Up Link -->
    <Hyperlink text="Don't have an account? Sign Up" onAction="#handleSignUpLink"
               GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2" GridPane.halignment="CENTER"/>

    <!-- Quit Button -->
    <Button fx:id="quitButton" text="Quit" onAction="#handleQuit" 
            cancelButton="true" style="-fx-background-color: #f44336; -fx-text-fill: white;" 
            GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2" GridPane.halignment="CENTER"/>

</GridPane>
