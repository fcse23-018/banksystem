<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<GridPane fx:controller="com.bankingsystem.controller.SignUpController" 
          xmlns:fx="http://javafx.com/fxml/1" 
          alignment="CENTER" hgap="10" vgap="10" style="-fx-background-color: #f0f4f8;">
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>
    <columnConstraints>
        <ColumnConstraints minWidth="120" prefWidth="120" hgrow="SOMETIMES" />
        <ColumnConstraints minWidth="250" prefWidth="250" hgrow="SOMETIMES" />
    </columnConstraints>

    <!-- Title -->
    <Label text="Create Your Account" style="-fx-font-size: 24px; -fx-font-weight: bold;" 
           GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2" GridPane.halignment="CENTER"/>

    <!-- First Name -->
    <Label text="First Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
    <TextField fx:id="firstNameField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

    <!-- Surname -->
    <Label text="Surname:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
    <TextField fx:id="surnameField" GridPane.columnIndex="1" GridPane.rowIndex="2" />

    <!-- Address -->
    <Label text="Address:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
    <TextField fx:id="addressField" GridPane.columnIndex="1" GridPane.rowIndex="3" />

    <!-- ID Number -->
    <Label text="ID Number:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
    <TextField fx:id="idNumberField" GridPane.columnIndex="1" GridPane.rowIndex="4" />

    <!-- Password -->
    <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
    <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="5" />

    <!-- Confirm Password -->
    <Label text="Confirm Password:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
    <PasswordField fx:id="confirmPasswordField" GridPane.columnIndex="1" GridPane.rowIndex="6" />

    <!-- Sign Up Button -->
    <Button fx:id="signUpButton" text="Sign Up" onAction="#handleSignUp" 
            defaultButton="true" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" 
            GridPane.columnIndex="1" GridPane.rowIndex="7" GridPane.halignment="RIGHT"/>

    <!-- Back to Login Link -->
    <Hyperlink text="Already have an account? Log In" onAction="#handleLoginLink"
               GridPane.columnIndex="0" GridPane.rowIndex="8" GridPane.columnSpan="2" GridPane.halignment="CENTER"/>

</GridPane>
